{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "lib": ["ESNext"],
    "allowJs": true,
    "strict": true,
    "resolveJsonModule": true,
    "skipLibCheck": false,
    "module": "esnext",
    "checkJs": true,
    "moduleResolution": "bundler",
    "composite": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "types": ["@types/node"]
  },
  "include": ["src/**/*.ts", "package.json", "vite.config.ts", "types/**/*.d.ts"]
}
